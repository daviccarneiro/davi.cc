---
import { Image } from 'astro:assets';
import myProfilePic from '../assets/davi.jpeg';

const currentPath = Astro.url.pathname;
const isContentPage =
  currentPath.startsWith('/resources') ||
  currentPath.startsWith('/contact') ||
  currentPath.startsWith('/cv') ||
  currentPath.startsWith('/book-a-call');
---

{isContentPage && (
  <header class="mobile-header">
    <div class="left-group">
      <a href="/" class="brand" aria-label="Página inicial">
        <Image
          src={myProfilePic}
          alt="Davi Carneiro"
          width={32}
          height={32}
          format="webp"
          class="avatar"
        />
      </a>
      <a href="/" class="mobile-back" data-i18n-key="nav.backHome">Voltar ao início</a>
    </div>
  </header>
)}

<style>
  .mobile-header {
    display: none;
  }

  @media (max-width: 768px) {
    .mobile-header {
      display: flex;
      align-items: center;
      padding: 0.7rem 1rem;
      background: color-mix(in oklab, var(--color-bg) 98%, white 2%);
      border-bottom: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
    }

    .left-group {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
    }

    .brand {
      display: inline-flex;
      align-items: center;
      text-decoration: none;
    }

    .avatar {
      width: 32px;
      height: 32px;
      border-radius: 999px;
      border: 2px solid color-mix(in oklab, var(--color-bg) 96%, transparent);
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12);
    }

    .mobile-back {
      text-decoration: none;
      font-weight: 600;
      font-size: 0.9rem;
      color: var(--color-text);
      border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
      border-radius: 10px;
      background: color-mix(in oklab, var(--color-bg) 92%, transparent);
      padding: 0.38rem 0.7rem;
      line-height: 1;
    }
  }
</style>
