---
import Layout from '../layouts/Layout.astro';
---

<Layout title="davi.cc | Book a call" noIndex={true} hideContentBack={true}>
  <section class="call">
    <header class="call-intro">
      <a href="/" class="back-inline" data-i18n-key="nav.backHome">Voltar ao início</a>
      <p class="lead" data-i18n-key="call.description">Pick an available time slot on the calendar to schedule a call.</p>
      <span class="intro-spacer" aria-hidden="true"></span>
    </header>

    <div class="embed">
      <!-- Google Calendar Appointment Scheduling begin -->
      <iframe
        src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ0uOEPEX_7as3Ak9kvVlmn7fMBs-2m3Y4VsiMkFz3QjBnxsnA5ntXQZpudRRrADcXoVaq-9xVLH?gv=true"
        style="border: 0"
        width="100%"
        height="720"
        frameborder="0"
        loading="lazy"
      ></iframe>
      <!-- end Google Calendar Appointment Scheduling -->
    </div>
  </section>

  <style>
    .call {
      display: grid;
      gap: 1rem;
    }

    .call-intro {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: 0.85rem;
      width: 100%;
    }

    .back-inline {
      display: inline-flex;
      justify-self: start;
      width: auto;
      white-space: nowrap;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.92rem;
      line-height: 1;
      padding: 0.58rem 0.8rem;
      border-radius: 10px;
      border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
      background: color-mix(in oklab, var(--color-bg) 94%, transparent);
      transition: background-color 180ms ease, border-color 180ms ease;
    }

    .back-inline:hover {
      background: color-mix(in oklab, var(--color-bg) 86%, transparent);
      border-color: color-mix(in oklab, var(--color-border) 85%, transparent);
      opacity: 1;
    }

    .lead {
      color: var(--color-text-soft);
      font-size: 1.05rem;
      max-width: 100%;
      text-align: center;
      white-space: nowrap;
    }

    .intro-spacer {
      justify-self: end;
      width: 1px;
      height: 1px;
      opacity: 0;
    }

    .embed {
      border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
      background: color-mix(in oklab, var(--color-surface) 96%, transparent);
      border-radius: var(--border-radius-md);
      box-shadow: var(--shadow-surface);
      overflow: hidden;
    }
    .embed :global(iframe) {
      display: block;
      width: 100%;
      height: 720px;
      border: 0;
      background: #fff;
    }

    @media (max-width: 768px) {
      .call-intro {
        display: block;
      }

      .back-inline {
        display: none;
      }

      .intro-spacer {
        display: none;
      }

      .lead {
        white-space: normal;
      }

      .embed :global(iframe) {
        height: 640px;
      }
    }
  </style>
</Layout>
