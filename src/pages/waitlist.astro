---
import Layout from '../layouts/Layout.astro';
---

<Layout title="davi.cc | Waitlist" hideContentBack={true}>
  <section class="waitlist">
    <div class="waitlist-intro">
      <a href="/" class="back-inline" data-i18n-key="nav.backHome">Voltar ao início</a>
      <p class="subtitle" data-i18n-key="waitlist.subtitle">Seja o primeiro a saber do lançamento.</p>
      <span class="intro-spacer" aria-hidden="true"></span>
    </div>

    <div class="waitlist-card">
      <div class="waitlist-header">
        <h2 data-i18n-key="waitlist.title">Lista de Espera</h2>
        <p data-i18n-key="waitlist.description">Deixe seu email e nome para entrar na lista de espera do meu novo app. Você será notificado assim que lançar.</p>
      </div>

      <form class="waitlist-form" id="waitlist-form" novalidate>
        <div class="field">
          <label for="name" data-i18n-key="waitlist.nameLabel">Nome</label>
          <input type="text" id="name" name="name" required placeholder="Seu nome" data-i18n-placeholder="waitlist.namePh" />
        </div>

        <div class="field">
          <label for="email" data-i18n-key="waitlist.emailLabel">Email</label>
          <input type="email" id="email" name="email" required placeholder="voce@exemplo.com" data-i18n-placeholder="waitlist.emailPh" />
        </div>

        <button type="submit" class="btn-primary" id="submit-btn" data-i18n-key="waitlist.submit">Entrar na Lista</button>
        <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
      </form>
    </div>
  </section>

  <style>
    .waitlist {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .waitlist-intro {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      column-gap: 0.85rem;
      width: 100%;
    }

    .back-inline {
      display: inline-flex;
      justify-self: start;
      width: auto;
      white-space: nowrap;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.92rem;
      line-height: 1;
      padding: 0.58rem 0.8rem;
      border-radius: 10px;
      border: 1px solid color-mix(in oklab, var(--color-border) 70%, transparent);
      background: color-mix(in oklab, var(--color-bg) 94%, transparent);
      transition: background-color 180ms ease, border-color 180ms ease;
    }

    .back-inline:hover {
      background: color-mix(in oklab, var(--color-bg) 86%, transparent);
      border-color: color-mix(in oklab, var(--color-border) 85%, transparent);
      opacity: 1;
    }

    .subtitle {
      color: var(--color-text-soft);
      font-size: 1.05rem;
      max-width: 100%;
      text-align: center;
      white-space: nowrap;
    }

    .intro-spacer {
      justify-self: end;
      width: 1px;
      height: 1px;
      opacity: 0;
    }

    .waitlist-card {
      border: 1px solid color-mix(in oklab, var(--color-border) 65%, transparent);
      background: color-mix(in oklab, var(--color-surface) 90%, transparent);
      border-radius: var(--border-radius-md);
      padding: clamp(1.25rem, 1.2vw + 1rem, 1.75rem);
      box-shadow: 0 18px 45px rgba(38, 56, 120, 0.12);
      backdrop-filter: blur(10px);
    }

    .waitlist-header {
      margin-bottom: 1.5rem;
    }

    .waitlist-header h2 {
      margin: 0 0 0.5rem;
      font-size: 1.35rem;
    }

    .waitlist-header p {
      margin: 0;
      color: var(--color-text-soft);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .waitlist-form {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .field {
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }

    label {
      font-weight: 600;
    }

    input {
      font: inherit;
      color: var(--color-text);
      background: color-mix(in oklab, var(--color-surface) 80%, transparent);
      border: 1px solid color-mix(in oklab, var(--color-border) 60%, transparent);
      border-radius: var(--border-radius-sm);
      padding: 0.75rem 0.9rem;
      outline: none;
      transition: border-color 200ms ease, box-shadow 200ms ease, background-color 200ms ease;
    }

    input:focus {
      border-color: color-mix(in oklab, var(--color-primary) 55%, transparent);
      background: color-mix(in oklab, var(--color-surface) 95%, transparent);
      box-shadow: 0 0 0 4px color-mix(in oklab, var(--color-primary) 22%, transparent);
    }

    .btn-primary {
      align-self: flex-start;
      background: linear-gradient(135deg, color-mix(in oklab, var(--color-primary) 90%, white), var(--color-primary));
      color: #fff;
      border: 0;
      border-radius: 999px;
      padding: 0.65rem 1.5rem;
      cursor: pointer;
      font-weight: 600;
      box-shadow: 0 16px 35px rgba(61, 123, 255, 0.28);
      transition: transform 200ms ease, box-shadow 200ms ease;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 22px 45px rgba(61, 123, 255, 0.32);
    }

    .form-status {
      margin-top: 0.25rem;
      min-height: 1.25rem;
      font-size: 0.95rem;
      color: var(--color-text-soft);
    }
    .form-status.success {
      color: #1c7c2c;
    }
    .form-status.error {
      color: #b42318;
    }

    @media (max-width: 768px) {
      .waitlist-intro {
        display: block;
      }

      .back-inline {
        display: none;
      }

      .intro-spacer {
        display: none;
      }

      .subtitle {
        white-space: normal;
      }
    }
  </style>

  <script>
    function initWaitlistForm() {
      const formNode = document.getElementById('waitlist-form');
      const statusNode = document.getElementById('form-status');
      const submitBtnNode = document.getElementById('submit-btn');

      if (
        formNode instanceof HTMLFormElement &&
        statusNode instanceof HTMLParagraphElement &&
        submitBtnNode instanceof HTMLButtonElement
      ) {
        if (formNode.dataset.bound === 'true') return;
        formNode.dataset.bound = 'true';

        const t = (window as any).__i18n?.t || ((key: string) => key);

        const setStatus = (message: string, type: '' | 'success' | 'error' = '') => {
          statusNode.textContent = message || '';
          statusNode.classList.remove('success', 'error');
          if (type) statusNode.classList.add(type);
        };

        const getFieldValue = (id: string): string => {
          const el = document.getElementById(id);
          if (el instanceof HTMLInputElement) {
            return el.value.trim();
          }
          return '';
        };

        formNode.addEventListener('submit', async (e) => {
          e.preventDefault();
          setStatus(t('waitlist.status.sending'));
          submitBtnNode.disabled = true;

          try {
            const payload = {
              name: getFieldValue('name'),
              email: getFieldValue('email')
            };

            const response = await fetch('/api/waitlist', {
              method: 'POST',
              headers: {
                'Accept': 'application/json',
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(payload)
            });

            if (response.ok) {
              setStatus(t('waitlist.status.success'), 'success');
              formNode.reset();
            } else {
              let errorMsg = t('waitlist.status.error');
              try {
                const data = await response.json();
                if (data && (data.error || data.message)) {
                  errorMsg = data.error || data.message;
                }
              } catch {}
              setStatus(errorMsg, 'error');
            }
          } catch {
            setStatus(t('waitlist.status.network'), 'error');
          } finally {
            submitBtnNode.disabled = false;
          }
        });
      }
    }

    initWaitlistForm();
    document.addEventListener('astro:page-load', initWaitlistForm);
    document.addEventListener('astro:after-swap', initWaitlistForm);
  </script>
</Layout>
