# n8n webhook URL for the waitlist feature
# In production, set these as secrets on the Cloudflare Worker (dashboard:
# Worker "davicc" → Settings → Variables and Secrets, or `wrangler secret put`).
# For local dev with the Cloudflare adapter, put them in .dev.vars (same KEY=value format).
N8N_WEBHOOK_URL=https://nina.tail566006.ts.net/webhook/waitlist

# Resend (from existing contact form):
# RESEND_API_KEY=
# RESEND_FROM=
# RESEND_TO=
